%%{init: {"theme": "base", "themeVariables": {
  "primaryColor": "#4f46e5",
  "primaryTextColor": "#ffffff",
  "primaryBorderColor": "#3730a3",
  "lineColor": "#6b7280",
  "clusterBkg": "#f8fafc",
  "clusterBorder": "#94a3b8"
}}}%%
graph TB

  %% ── Frontend ──────────────────────────────────────────────────────────
  subgraph frontend["Frontend  ·  React · TypeScript · Vite"]
    direction LR

    subgraph local_fe["🔒  Localhost only"]
      direction TB
      setup_page["⚙️ Setup wizard"]
      admin_page["🔧 Admin panel"]
    end

    user_page["💎 Gem runner"]
  end

  style local_fe fill:#ede9fe,stroke:#7c3aed,color:#4c1d95

  %% ── Backend ───────────────────────────────────────────────────────────
  subgraph backend["Backend"]
    direction TB

    %% Interface layer
    subgraph ifaces["Interface layer"]
      direction LR
      setup_iface["Setup interface<br/>port 7071 · 🔒 localhost only"]
      exec_iface["Execution interface<br/>port 7770 · LAN + localhost"]
    end

    style setup_iface fill:#ede9fe,stroke:#7c3aed,color:#4c1d95
    style exec_iface  fill:#eef2ff,stroke:#6366f1,color:#1e1b4b

    %% Router layer
    subgraph routers["Router layer"]
      direction LR

      subgraph r_setup_only["Setup only"]
        r_setup["Setup wizard<br/>(6-step installer)"]
      end

      subgraph r_exec_only["Execution only"]
        direction LR
        r_auth["Auth · Session"]
        r_gems["Gems<br/>task runner · SSE"]
        r_docs["Documents<br/>Markitdown · AI summary"]
        r_bundle["Bundle<br/>export · import"]
      end

      subgraph r_shared["Shared"]
        direction LR
        r_config["Config · i18n"]
        r_system["System checks"]
        r_ollama_r["Ollama<br/>install · pull · build"]
      end
    end

    style r_setup_only fill:#ede9fe,stroke:#7c3aed,color:#4c1d95
    style r_exec_only  fill:#eef2ff,stroke:#6366f1,color:#1e1b4b
    style r_shared     fill:#f0fdf4,stroke:#22c55e,color:#14532d

    %% Interface → router connections
    setup_iface --> r_setup_only
    setup_iface --> r_shared

    exec_iface --> r_exec_only
    exec_iface --> r_shared
  end

  %% ── External resources ────────────────────────────────────────────────
  ollama_srv[("🤖 Ollama server")]
  storage[("💾 SQLite DB<br/>+ file storage")]

  style ollama_srv fill:#fef3c7,stroke:#d97706,color:#78350f
  style storage    fill:#f1f5f9,stroke:#64748b,color:#1e293b

  %% ── Frontend → backend ────────────────────────────────────────────────
  setup_page --> setup_iface
  admin_page --> exec_iface
  user_page  --> exec_iface

  %% ── Routers → external resources ──────────────────────────────────────
  r_ollama_r --> ollama_srv
  r_gems     -- "inference (SSE)" --> ollama_srv
  r_docs     -- "AI summary" --> ollama_srv

  r_auth   --> storage
  r_gems   --> storage
  r_docs   --> storage
  r_bundle --> storage
  r_config --> storage
